# Last9 OpenTelemetry Configuration
# Copy this file to .env and customize with your Last9 credentials

# Service identification
OTEL_SERVICE_NAME=rust-otel-example
OTEL_SERVICE_VERSION=1.0.0

# Last9 OTLP Endpoint
# Get your endpoint from Last9 dashboard: https://app.last9.io
# Available regions: otlp-aps1.last9.io (Asia Pacific), otlp.last9.io (US)
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.last9.io:443

# Basic Auth Header (base64 encoded credentials from Last9 dashboard)
# Format: Authorization=Basic <base64(username:password)>
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic YOUR_BASE64_CREDENTIALS

# Resource Attributes
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development

# Sampling configuration
# Options: always_on, always_off, traceid_ratio, parentbased_always_on, parentbased_traceid_ratio
OTEL_TRACES_SAMPLER=parentbased_always_on
# For ratio-based sampling (0.0 to 1.0)
# OTEL_TRACES_SAMPLER_ARG=0.5

# Deployment Environment
DEPLOYMENT_ENVIRONMENT=development

# Rust logging
RUST_LOG=info,rust_otel_auto=debug
